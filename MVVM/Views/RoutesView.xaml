<UserControl x:Class="PortBridgeShipping.MVVM.Views.RoutesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:PortBridgeShipping.MVVM.Views"
             xmlns:viewModel="clr-namespace:PortBridgeShipping.MVVM.ViewModels"
             xmlns:coreProp="clr-namespace:PortBridgeShipping.Core.DependencyProperties"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=viewModel:RoutesViewModel}"
             d:DesignHeight="640"
             d:DesignWidth="1200">

    <Border BorderBrush="LightGray"
            BorderThickness="1">

        <TabControl Background="Transparent"
                    BorderThickness="0">

            <!-- ================= TAB 1 ================= -->
            <TabItem Header="Routes Segments">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto"
                                              MinWidth="200"
                                              MaxWidth="260" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="65" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0"
                                    Grid.Row="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <TextBox Grid.Column="0"
                                     Grid.Row="0"
                                     Width="200"
                                     Height="40"
                                     Text="{Binding SearchBoxText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SearchBoxTheme}"
                                     coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Search-Icon-32px.png"
                                     x:Name="TextBox_Search" />

                            <ComboBox Grid.Column="0"
                                      Grid.Row="0"
                                      Margin="15, 0"
                                      Width="140"
                                      Height="25"
                                      Background="White"
                                      ItemsSource="{Binding Filters}"
                                      SelectedItem="{Binding SelectedFilter}" />

                            <ComboBox Grid.Column="0"
                                      Grid.Row="0"
                                      Width="140"
                                      Height="25"
                                      Background="White"
                                      ItemsSource="{Binding ViewModes}"
                                      SelectedItem="{Binding SelectedViewMode}"
                                      SelectionChanged="ComboBox_ViewMode_SelectionChanged"
                                      x:Name="ComboBox_ViewMode"/>
                        </StackPanel>

                        <!-- Content Control -->
                        <Grid Grid.Column="0"
                              Grid.Row="1">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="350" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Routes -->
                            <DataGrid Grid.Column="0"
                                      Margin="15, 0, 0, 15"
                                      Width="Auto"
                                      MaxWidth="400"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      FontSize="13"
                                      CanUserResizeColumns="False"
                                      CanUserResizeRows="False"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding Routes}"
                                      SelectedItem="{Binding SelectedRoute}">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Id"
                                                        Width="80"
                                                        Binding="{Binding Id}"/>
                                    
                                    <DataGridTextColumn Header="Route"
                                                        Width="*"
                                                        MinWidth="150"
                                                        Binding="{Binding Name}" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Segments -->
                            <DataGrid Grid.Column="1"
                                      Margin="15, 0, 15, 15"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      FontSize="13"
                                      CanUserResizeColumns="False"
                                      CanUserResizeRows="False"
                                      ItemsSource="{Binding RouteSegments}"
                                      SelectedItem="{Binding SelectedRouteSegment}">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Order"
                                                        Width="Auto"
                                                        MinWidth="60"
                                                        Binding="{Binding Order}" />

                                    <DataGridTextColumn Header="From"
                                                        Width="Auto"
                                                        MinWidth="140"
                                                        Binding="{Binding From}" />

                                    <DataGridTextColumn Header="To"
                                                        Width="Auto"
                                                        MinWidth="140"
                                                        Binding="{Binding To}" />

                                    <DataGridTextColumn Header="Route"
                                                        Width="*"
                                                        Binding="{Binding RouteId}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <!-- Control Panel -->
                        <StackPanel Grid.Column="1"
                                    Grid.Row="1"
                                    Margin="0, 0, 15, 0"
                                    Orientation="Vertical">

                            <TextBlock Text="Route Name"
                                       FontSize="16"
                                       Foreground="White"
                                       FontFamily="/PortBridgeShipping;component/Fonts/Cagliostro-Regular.ttf#Cagliostro" />
                            <TextBox Height="25"
                                     Text="{Binding Route.Name, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="5, 0"
                                     VerticalContentAlignment="Center"
                                     x:Name="TextBox_Name" />

                            <Label Height="1"
                                   Margin="10, 15"
                                   Background="White"/>

                            <TextBlock Text="From"
                                       Margin="0, 20, 0, 0"
                                       FontSize="16"
                                       Foreground="White"
                                       FontFamily="/PortBridgeShipping;component/Fonts/Cagliostro-Regular.ttf#Cagliostro" />
                            <TextBox Height="25"
                                     Text="{Binding RouteSegment.From, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="20"
                                     Padding="5, 0"
                                     VerticalContentAlignment="Center"
                                     x:Name="TextBox_From" />

                            <TextBlock Text="To"
                                       Margin="0, 20, 0, 0"
                                       FontSize="16"
                                       Foreground="White"
                                       FontFamily="/PortBridgeShipping;component/Fonts/Cagliostro-Regular.ttf#Cagliostro" />
                            <TextBox Height="25"
                                     Text="{Binding RouteSegment.To, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="20"
                                     Padding="5, 0"
                                     VerticalContentAlignment="Center"
                                     x:Name="TextBox_To" />
                        </StackPanel>
                    </Grid>

                    <!-- Buttons Section -->
                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                Background="#bba9c9"
                                x:Name="StackPanel_Route">

                        <Button Content="Add"
                                Height="35"
                                FontSize="17"
                                Foreground="White"
                                Margin="0, 55, 0, 0"
                                Style="{StaticResource DefaultButtonTheme}"
                                coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Plus-Icon-32px.png"
                                Command="{Binding RouteRouteSegment_AddCommand}"
                                CommandParameter="{Binding Routes}"
                                x:Name="Button_Add_Route" />

                        <Button Content="Update"
                                Height="35px"
                                FontSize="17px"
                                Foreground="White"
                                Margin="0, 20, 0, 0"
                                Style="{StaticResource DefaultButtonTheme}"
                                coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Update-Icon-32px.png"
                                Command="{Binding RouteRouteSegment_UpdateCommand}"
                                CommandParameter="{Binding SelectedRoute}"
                                x:Name="Button_Update_Route" />

                        <Button Content="Delete"
                                Height="35"
                                FontSize="17"
                                Foreground="White"
                                Margin="0, 20, 0, 0"
                                Style="{StaticResource DefaultButtonTheme}"
                                coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Delete-Icon-32px.png"
                                Command="{Binding RouteRouteSegment_RemoveCommand}"
                                CommandParameter="{Binding SelectedRoute}"
                                x:Name="Button_Delete_Route" />


                        <Button Content="Clear"
                                Height="35"
                                FontSize="17"
                                Foreground="White"
                                Margin="0, 145, 0, 0"
                                Style="{StaticResource DefaultButtonTheme}"
                                coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Trash-Icon-32px.png"
                                Command="{Binding ClearCommand}"
                                x:Name="Button_Clear" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                Background="#bba9c9"
                                IsEnabled="False"
                                Visibility="Hidden"
                                x:Name="StackPanel_Segment">
                        
                        <Button Content="Add"
                                Height="35"
                                FontSize="17"
                                Foreground="White"
                                Margin="0, 55, 0, 0"
                                Style="{StaticResource DefaultButtonTheme}"
                                coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Plus-Icon-32px.png"
                                Command="{Binding RouteRouteSegment_AddCommand}"
                                CommandParameter="{Binding RouteSegments}"
                                x:Name="Button_Add_Segment" />

                        <Button Content="Update"
                                Height="35px"
                                FontSize="17px"
                                Foreground="White"
                                Margin="0, 20, 0, 0"
                                Style="{StaticResource DefaultButtonTheme}"
                                coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Update-Icon-32px.png"
                                Command="{Binding RouteRouteSegment_UpdateCommand}"
                                CommandParameter="{Binding SelectedRouteSegment}"
                                x:Name="Button_Update_Segment" />

                        <Button Content="Delete"
                                Height="35"
                                FontSize="17"
                                Foreground="White"
                                Margin="0, 20, 0, 0"
                                Style="{StaticResource DefaultButtonTheme}"
                                coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Delete-Icon-32px.png"
                                Command="{Binding RouteRouteSegment_RemoveCommand}"
                                CommandParameter="{Binding SelectedRouteSegment}"
                                x:Name="Button_Delete_Segment" />

                        <Button Content="Clear"
                                Height="35"
                                FontSize="17"
                                Foreground="White"
                                Margin="0, 145, 0, 0"
                                Style="{StaticResource DefaultButtonTheme}"
                                coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Trash-Icon-32px.png"
                                Command="{Binding RouteRouteSegment_ClearCommand}"
                                x:Name="Button_Clear_Segment" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ================= TAB 2 ================= -->
            <TabItem Header="Transport Binding">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="160" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto"
                                              MinWidth="200"
                                              MaxWidth="260" />
                        </Grid.ColumnDefinitions>
                        
                        <Grid.RowDefinitions>
                            <RowDefinition Height="65" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Column="0"
                                    Grid.Row="0"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <TextBox Grid.Column="0"
                                     Grid.Row="0"
                                     Width="200"
                                     Height="40"
                                     Text="{Binding SearchBoxText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SearchBoxTheme}"
                                     coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Search-Icon-32px.png"
                                     x:Name="TextBox_Search_Rst" />

                            <ComboBox Grid.Column="0"
                                      Grid.Row="0"
                                      Margin="15, 0"
                                      Width="140"
                                      Height="25"
                                      Background="White"
                                      ItemsSource="{Binding Filters}"
                                      SelectedItem="{Binding SelectedFilter}" />
                        </StackPanel>

                        <!-- Content Control -->
                        <Grid Grid.Column="0"
                              Grid.Row="1"
                              Margin="15, 0">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="350" />
                                <ColumnDefinition Width="*" />
                                
                            </Grid.ColumnDefinitions>

                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>

                            <!-- Routes -->
                            <DataGrid Grid.Column="0"
                                      Margin="0, 0, 0, 15"
                                      Width="Auto"
                                      MaxWidth="400"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      FontSize="13"
                                      CanUserResizeColumns="False"
                                      CanUserResizeRows="False"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding Routes}"
                                      SelectedItem="{Binding SelectedRoute}">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Id"
                                                        Width="80"
                                                        Binding="{Binding Id}" />

                                    <DataGridTextColumn Header="Route"
                                                        Width="*"
                                                        MinWidth="150"
                                                        Binding="{Binding Name}" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Segments -->
                            <DataGrid Grid.Column="1"
                                      Margin="15, 0, 0, 15"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      FontSize="13"
                                      CanUserResizeColumns="False"
                                      CanUserResizeRows="False"
                                      ItemsSource="{Binding RouteSegments}"
                                      SelectedItem="{Binding SelectedRouteSegment}"
                                      x:Name="DataGridView_Segments_Rst">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Order"
                                                        Width="Auto"
                                                        MinWidth="130"
                                                        Binding="{Binding Order}" />

                                    <DataGridTextColumn Header="From"
                                                        Width="Auto"
                                                        MinWidth="190"
                                                        Binding="{Binding From}" />

                                    <DataGridTextColumn Header="To"
                                                        Width="*"
                                                        Binding="{Binding To}" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- RouteSegment Transports -->
                            <DataGrid Grid.Column="0"
                                      Grid.Row="1"
                                      Margin="0, 0, 0, 15"
                                      Width="Auto"
                                      MaxWidth="400"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      FontSize="13"
                                      CanUserResizeColumns="False"
                                      CanUserResizeRows="False"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ItemsSource="{Binding RouteSegmentTransports}"
                                      SelectedItem="{Binding SelectedRouteSegmentTransport}">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="RouteSegment"
                                                        Width="140"
                                                        Binding="{Binding RouteSegment}" />

                                    <DataGridTextColumn Header="Transport"
                                                        Width="*"
                                                        MinWidth="150"
                                                        Binding="{Binding Transport}" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Transports -->
                            <DataGrid Grid.Column="1"
                                      Grid.Row="1"
                                      Margin="15, 0, 0, 15"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      FontSize="13"
                                      CanUserResizeColumns="False"
                                      CanUserResizeRows="False"
                                      ItemsSource="{Binding Transports}"
                                      SelectedItem="{Binding SelectedTrnasport}"
                                      x:Name="DataGridView_Transports_Rst">

                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Number"
                                                        Width="Auto"
                                                        MinWidth="170"
                                                        Binding="{Binding TransportNumber}"/>

                                    <DataGridTextColumn Header="Name"
                                                        Width="Auto"
                                                        MinWidth="160"
                                                        Binding="{Binding Name}"/>

                                    <DataGridTextColumn Header="Type"
                                                        Width="Auto"
                                                        MinWidth="150"
                                                        Binding="{Binding TransportType}"/>

                                    <DataGridTextColumn Header="Capacity"
                                                        Width="*"
                                                        Binding="{Binding Capacity}"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>

                        <!-- Control Panel -->
                        <StackPanel Grid.Column="1"
                                    Grid.Row="1"
                                    Margin="0, 0, 15, 0"
                                    Orientation="Vertical">

                            <TextBlock Text="Route Segment Id"
                                       FontSize="16"
                                       Foreground="White"
                                       FontFamily="/PortBridgeShipping;component/Fonts/Cagliostro-Regular.ttf#Cagliostro" />
                            <ComboBox Height="25"
                                      Text="Type"
                                      Padding="5, 0"
                                      Background="White"
                                      VerticalContentAlignment="Center"
                                      ItemsSource="{Binding RouteSegments}"
                                      SelectedItem="{Binding SelectedRouteSegmentTransport.RouteSegmentId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="From" />

                            <TextBlock Text="Transport Id"
                                       Margin="0, 20, 0, 0"
                                       FontSize="16"
                                       Foreground="White"
                                       FontFamily="/PortBridgeShipping;component/Fonts/Cagliostro-Regular.ttf#Cagliostro" />
                            <ComboBox Height="25"
                                      Text="Type"
                                      Padding="5, 0"
                                      Background="White"
                                      VerticalContentAlignment="Center"
                                      ItemsSource="{Binding Transports}"
                                      SelectedItem="{Binding SelectedRouteSegmentTransport.TransportId}"
                                      SelectedValuePath="Id"
                                      DisplayMemberPath="TransportNumber" />
                        </StackPanel>
                    </Grid>

                    <!-- Buttons Section -->
                    <StackPanel Grid.Column="1"
                                Orientation="Vertical"
                                Background="#bba9c9"
                                x:Name="StackPanel_Route_Rst">

                        <Button Content="Bind"
                                Height="35"
                                FontSize="17"
                                Foreground="White"
                                Margin="0, 55, 0, 0"
                                Style="{StaticResource DefaultButtonTheme}"
                                coreProp:ImageIconProperties.IconSource="/Images/Icons/RoutesWindow/Chain-Icon-32px.png"
                                Command="{Binding RouteSegmentTransport_BindCommand}"
                                CommandParameter="{Binding Routes}"
                                x:Name="Button_Add_Rst" />

                        <Button Content="Update"
                                Height="35px"
                                FontSize="17px"
                                Foreground="White"
                                Margin="0, 20, 0, 0"
                                Style="{StaticResource DefaultButtonTheme}"
                                coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Update-Icon-32px.png"
                                Command="{Binding RouteSegmentTransport_UpdateCommand}"
                                CommandParameter="{Binding SelectedRoute}"
                                x:Name="Button_Update_Rst" />

                        <Button Content="Delete"
                                Height="35"
                                FontSize="17"
                                Foreground="White"
                                Margin="0, 20, 0, 0"
                                Style="{StaticResource DefaultButtonTheme}"
                                coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Delete-Icon-32px.png"
                                Command="{Binding RouteSegmentTransport_RemoveCommand}"
                                CommandParameter="{Binding SelectedRoute}"
                                x:Name="Button_Delete_Rst" />


                        <Button Content="Clear"
                                Height="35"
                                FontSize="17"
                                Foreground="White"
                                Margin="0, 145, 0, 0"
                                Style="{StaticResource DefaultButtonTheme}"
                                coreProp:ImageIconProperties.IconSource="/Images/Icons/Global/Trash-Icon-32px.png"
                                Command="{Binding RouteSegmentTransport_ClearForm}"
                                x:Name="Button_Clear_Rst" />
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ================= TAB 3 ================= -->
            <TabItem Header="Show All Routes">
                
            </TabItem>
        </TabControl>
    </Border>
</UserControl>
