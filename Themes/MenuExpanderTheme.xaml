<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style x:Key="MenuExpanderTheme"
           TargetType="Expander">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Expander">
                    <StackPanel>
                        <!-- Шапка -->
                        <ToggleButton IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                      VerticalAlignment="Stretch"
                                      HorizontalAlignment="Stretch"
                                      Background="Transparent"
                                      Foreground="{TemplateBinding Foreground}"
                                      MinHeight="45">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="BackgroundBrdr">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock x:Name="Arrow"
                                                       Text="▶"
                                                       VerticalAlignment="Center"
                                                       Margin="22, 0, 0, 0" />
                                            
                                            <ContentPresenter Grid.Column="1"
                                                              ContentSource="Content"
                                                              VerticalAlignment="Center"
                                                              Margin="20, 0, 0, 0" />
                                        </Grid>
                                    </Border>
                                    
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver"
                                                 Value="True">
                                            <Setter TargetName="BackgroundBrdr"
                                                    Property="Background"
                                                    Value="#8a779e" />
                                        </Trigger>
                                        
                                        <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=Expander}}"
                                                     Value="True">
                                            <Setter TargetName="Arrow"
                                                    Property="Text"
                                                    Value="▼" />

                                            <Setter TargetName="BackgroundBrdr"
                                                    Property="Background"
                                                    Value="#FF92889C" />
                                        </DataTrigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                            
                            <ContentPresenter ContentSource="Header" />
                        </ToggleButton>

                        <!-- Содержимое -->
                        <Border Background="#FFAD99C1">
                            <ContentPresenter x:Name="ExpandSite"
                                              Visibility="Collapsed"
                                              Margin="0, 5, 0, 0" />
                        </Border>
                    </StackPanel>
                    
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded"
                                 Value="True">

                            <Setter TargetName="ExpandSite"
                                    Property="Visibility"
                                    Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

        <Setter Property="Background"
                Value="Transparent" />
    </Style>
</ResourceDictionary>