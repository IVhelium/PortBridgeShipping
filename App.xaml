<Application x:Class="PortBridgeShipping.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:local="clr-namespace:PortBridgeShipping"
             xmlns:viewModel="clr-namespace:PortBridgeShipping.MVVM.ViewModels"
             xmlns:view="clr-namespace:PortBridgeShipping.MVVM.Views"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Themes -->
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/MenuButtonTheme.xaml" />
                <ResourceDictionary Source="/Themes/SearchBoxTheme.xaml" />

                <!-- Default Themes -->
                <ResourceDictionary Source="/Themes/DefaultThemes/DefaultButtonTheme.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
